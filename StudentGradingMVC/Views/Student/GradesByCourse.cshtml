@model List<StudentGradingMVC.Models.ViewModels.StudentCourseGradeVM>
@{
    ViewData["Title"] = "Grades by Course";
}

<h2>Grades by Course</h2>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info">There are no enrolled courses.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Semester</th>
                <th>Course</th>
                <th style="width:140px;">Grade</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model)
            {
                <tr>
                    <td>@x.Semester</td>
                    <td>@x.Title</td>
                    <td>@(x.Grade == null ? "-" : x.Grade)</td>
                </tr>
            }
        </tbody>
    </table>
}
