@model List<StudentGradingMVC.Models.ViewModels.StudentSemesterVM>

@{
    ViewData["Title"] = "Grades by Semester";
}

<h2>Grades by Semester</h2>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info">There are no enrolled courses.</div>
}
else
{
    @foreach (var sem in Model)
    {
        <h4 class="mt-4">Semester @sem.Semester</h4>

        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Course</th>
                    <th style="width:140px;">Grade</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in sem.Items)
                {
                    <tr>
                        <td>@x.Title</td>
                        <td>@(x.Grade == null ? "-" : x.Grade)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
