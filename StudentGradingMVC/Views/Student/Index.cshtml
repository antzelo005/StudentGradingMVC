@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="page-card">
    <h2 class="page-title">Student Dashboard</h2>
    <p class="text-muted mb-4">View your grades by course, by semester, or overall.</p>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="dash-card">
                <div class="dash-card-title">Grades by Course</div>
                <div class="dash-card-desc">See grades course-by-course, ordered by semester.</div>
                <a class="btn btn-primary w-100 mt-3" asp-controller="Student" asp-action="GradesByCourse">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dash-card">
                <div class="dash-card-title">Grades by Semester</div>
                <div class="dash-card-desc">Grouped view of your grades per semester.</div>
                <a class="btn btn-primary w-100 mt-3" asp-controller="Student" asp-action="GradesBySemester">
                    Open
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dash-card">
                <div class="dash-card-title">Overall Average</div>
                <div class="dash-card-desc">View your overall grade average (if available).</div>
                <a class="btn btn-primary w-100 mt-3" asp-controller="Student" asp-action="OverallGrades">
                    Open
                </a>
            </div>
        </div>
    </div>
</div>
