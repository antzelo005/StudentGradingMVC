@model StudentGradingMVC.Models.ViewModels.ProfessorGradeEntryVM
@{
    ViewData["Title"] = "Καταχώρηση Βαθμών";
}

<h2 class="mb-1">@Model.CourseTitle</h2>
<div class="text-muted mb-3">Εξάμηνο: @Model.CourseSemester</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}

<form asp-controller="Professor" asp-action="GradeEntryForm" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="CourseId" />

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Φοιτητής</th>
                <th style="width: 180px;">Βαθμός (0-10)</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Rows.Count; i++)
            {
                <tr>
                    <td>
                        @Model.Rows[i].StudentName
                        <input type="hidden" asp-for="Rows[i].StudentId" />
                        <input type="hidden" asp-for="Rows[i].StudentName" />
                    </td>
                    <td>
                        <input class="form-control" asp-for="Rows[i].Grade" placeholder="π.χ. 8.5" />
                        <span class="text-danger" asp-validation-for="Rows[i].Grade"></span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Αποθήκευση</button>
        <a class="btn btn-outline-secondary" asp-action="GradeEntry">Πίσω</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
