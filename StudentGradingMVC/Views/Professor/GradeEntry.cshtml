@model StudentGradingMVC.Models.ViewModels.ProfessorGradeEntrySelectCourseVM
@{
    ViewData["Title"] = "Καταχώρηση Βαθμών";
}

<h2 class="mb-3">Καταχώρηση Βαθμών</h2>

@if (Model.Courses == null || Model.Courses.Count == 0)
{
    <div class="alert alert-warning">Δεν υπάρχουν διαθέσιμα μαθήματα.</div>
}
else
{
    <div class="list-group">
        @foreach (var c in Model.Courses)
        {
            <a class="list-group-item list-group-item-action"
               asp-controller="Professor"
               asp-action="GradeEntryForm"
               asp-route-courseId="@c.CourseId">
                <div class="d-flex justify-content-between">
                    <strong>@c.Title</strong>
                    <span class="text-muted">Εξάμηνο: @c.Semester</span>
                </div>
            </a>
        }
    </div>
}
